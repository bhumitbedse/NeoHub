# ─────────────────────────────────────────────────────
#  NeoHub — Environment Variables
#  Copy this to .env and fill in your values
#  NEVER commit .env to git
# ─────────────────────────────────────────────────────

# ── GitHub OAuth App ─────────────────────────────────
# Create at: https://github.com/settings/developers
# Homepage URL:       http://localhost:4200
# Callback URL:       http://localhost:4200/auth/callback
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# ── GitHub Personal Access Token (for scraper) ───────
# Create at: https://github.com/settings/tokens
# Scopes needed: public_repo (read-only)
GITHUB_TOKEN=your_github_pat_here

# ── These are pre-filled for local dev — do not change
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/neohub
SPRING_DATASOURCE_USERNAME=neohub
SPRING_DATASOURCE_PASSWORD=neohub_dev
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=neohub_dev
JWT_SECRET=dev_only_secret_minimum_32_characters_long
